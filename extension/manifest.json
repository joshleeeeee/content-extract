{
  "manifest_version": 3,
  "name": "ContentExtract",
  "version": "1.8.2",
  "description": "Powerful tool to copy/export online documents (Feishu/Lark etc.) as Markdown or Rich Text.",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite",
    "storage",
    "unlimitedStorage",
    "debugger",
    "downloads",
    "system.display"
  ],
  "host_permissions": [
    "http://localhost/*",
    "*://*.jd.com/*",
    "*://*.jd.hk/*",
    "*://*.taobao.com/*",
    "*://*.tmall.com/*",
    "*://*.douyin.com/*",
    "*://*.xiaohongshu.com/*",
    "*://xhslink.com/*",
    "*://*.bilibili.com/*",
    "*://b23.tv/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.feishu.cn/*",
        "*://*.larksuite.com/*",
        "*://*.zhipin.com/*",
        "*://*.jd.com/*",
        "*://*.jd.hk/*",
        "*://*.taobao.com/*",
        "*://*.tmall.com/*",
        "*://*.douyin.com/*",
        "*://*.xiaohongshu.com/*",
        "*://xhslink.com/*",
        "*://*.bilibili.com/*",
        "*://b23.tv/*"
      ],
      "js": [
        "src/content/main.ts"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ContentExtract",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
